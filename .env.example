# RemitRoute environment. Copy to .env and fill in. Never commit .env.
# The web app (Next.js) and the heartbeat engine share this file. On a serverless
# host (e.g. Vercel) set the same keys as project environment variables, with
# APP_BASE_URL pointing at the deployed URL.

# --- Database (Neon Postgres). Shared by the app and the agent. ---
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- Celo RPC endpoints (primary plus fallback). viem uses a fallback transport. ---
CELO_RPC=https://forno.celo.org
CELO_RPC_FALLBACK=https://rpc.ankr.com/celo

# --- Onchain identity (ERC-8004 on Celo mainnet, chainId 42220). ---
# AGENT_ID is the registry token id, set after minting the agent. ERC8004_NETWORK
# selects the registry deployment (mainnet | sepolia). Defaults to mainnet (where the
# money engine runs); set sepolia explicitly only for testnet validation.
AGENT_ID=
ERC8004_NETWORK=mainnet

# --- Agent owner / execution. A funded hot wallet holding only working funds. ---
# Leave AGENT_PRIVATE_KEY empty while DRY_RUN=true. SERVER_WALLET_ADDRESS is the
# x402 payee (where paid FX-route calls settle).
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=
SERVER_WALLET_ADDRESS=

# --- Encryption key for per-user execution-wallet private keys at rest. ---
# 32 bytes hex (64 chars). Generate with: openssl rand -hex 32. THE single most
# critical secret: losing it makes every user wallet key undecryptable. Keep an
# offline encrypted backup (see RUNBOOK.md).
ENCRYPTION_KEY=
# Optional: the PREVIOUS encryption key, set only during a key rotation so old
# ciphertext still decrypts until rotate-encryption-key.ts re-encrypts every row.
# Remove it once rotation reports 0 failures. (see RUNBOOK.md)
ENCRYPTION_KEY_PREVIOUS=
# Current ENCRYPTION_KEY version, stamped into new ciphertext for lazy rotation.
ENCRYPTION_KEY_VERSION=1

# --- Session auth. HMAC secret for signed MiniPay session cookies. ---
# 32+ random bytes hex (openssl rand -hex 32). MUST be distinct from ENCRYPTION_KEY;
# never reuse the wallet-encryption key for sessions.
SESSION_SECRET=

# --- Safety. DRY_RUN builds and logs transactions but never sends them. ---
# Flip to false only with a funded key and tiny caps.
DRY_RUN=true

# --- User withdrawals. Pulls a user's own funds back to their MiniPay address. ---
# Real onchain even while the automated engine stays DRY_RUN. Defaults to false;
# set true in prod to enable real user withdrawals.
WITHDRAW_LIVE=false

# --- Fee abstraction. Which stablecoin pays gas: cUSD or USDC. ---
FEE_CURRENCY=cUSD

# --- Spend caps, in whole stablecoin units (USD-equivalent), plus the gas floor. ---
PER_TX_CAP=25
PER_USER_DAILY_CAP=50
GLOBAL_DAILY_CAP=500
GAS_FLOOR=0.5

# --- Circuit breaker + recovery tuning. ---
# Consecutive run failures before a schedule auto-pauses (stops burning gas).
MAX_CONSECUTIVE_FAILURES=5
# Minutes a tripped breaker waits before half-open auto-recovery (auto-resume).
ANOMALY_HALT_COOLDOWN_MIN=30
# Minutes a schedule may sit in "processing" (crash mid-cycle) before it is reclaimed.
RECLAIM_STALE_MIN=10

# --- Rate limiting for public/auth routes (DB-backed). ---
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=30

# --- Rule parser LLM (Anthropic-compatible endpoint). Used by /api/parse-rule. ---
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL=

# --- x402 paid FX-route API + IPFS pinning for the ERC-8004 registration. ---
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
PINATA_JWT=
# Master switch for the paid API. Defaults true; set false to return 404 (no settlement).
X402_ENABLED=true
# Dedicated, minimally-funded relayer that submits x402 settlements. Kept separate
# from AGENT_PRIVATE_KEY so forced settlements cannot drain the engine gas wallet.
# Falls back to AGENT_PRIVATE_KEY if unset.
RELAYER_PRIVATE_KEY=
RELAYER_WALLET_ADDRESS=

# --- Alerting + dead-man switch. ---
# Operator alert sink (Slack/generic webhook). notify() posts JSON here on halts/errors.
ALERT_WEBHOOK_URL=
# Dead-man's-switch ping (e.g. healthchecks.io) hit once per healthy heartbeat.
DEADMAN_PING_URL=

# --- Monitoring wallet for engine health checks (heartbeat only, not the web app). ---
MONITORING_PRIVATE_KEY=
MONITORING_WALLET_ADDRESS=

# --- Tracing (optional). Leave blank to disable. ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# --- App base URL. Set to the deployed origin (used by the x402 route and the
# ERC-8004 registration document). ---
APP_BASE_URL=http://localhost:3000

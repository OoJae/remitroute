# RemitRoute environment. Copy to .env and fill in. Never commit .env.
# The web app (Next.js) and the heartbeat engine share this file. On a serverless
# host (e.g. Vercel) set the same keys as project environment variables, with
# APP_BASE_URL pointing at the deployed URL.

# --- Database (Neon Postgres). Shared by the app and the agent. ---
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- Celo RPC endpoints (primary plus fallback). viem uses a fallback transport. ---
CELO_RPC=https://forno.celo.org
CELO_RPC_FALLBACK=https://rpc.ankr.com/celo

# --- Onchain identity (ERC-8004 on Celo mainnet, chainId 42220). ---
# AGENT_ID is the registry token id, set after minting the agent. ERC8004_NETWORK
# selects the registry deployment (mainnet | sepolia).
AGENT_ID=
ERC8004_NETWORK=mainnet

# --- Agent owner / execution. A funded hot wallet holding only working funds. ---
# Leave AGENT_PRIVATE_KEY empty while DRY_RUN=true. SERVER_WALLET_ADDRESS is the
# x402 payee (where paid FX-route calls settle).
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=
SERVER_WALLET_ADDRESS=

# --- Encryption key for per-user execution-wallet private keys at rest. ---
# 32 bytes hex (64 chars). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Safety. DRY_RUN builds and logs transactions but never sends them. ---
# Flip to false only with a funded key and tiny caps.
DRY_RUN=true

# --- Fee abstraction. Which stablecoin pays gas: cUSD or USDC. ---
FEE_CURRENCY=cUSD

# --- Spend caps, in whole stablecoin units (USD-equivalent), plus the gas floor. ---
PER_TX_CAP=25
PER_USER_DAILY_CAP=50
GLOBAL_DAILY_CAP=500
GAS_FLOOR=0.5

# --- Rule parser LLM (Anthropic-compatible endpoint). Used by /api/parse-rule. ---
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL=

# --- x402 paid FX-route API + IPFS pinning for the ERC-8004 registration. ---
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
PINATA_JWT=

# --- Monitoring wallet for engine health checks (heartbeat only, not the web app). ---
MONITORING_PRIVATE_KEY=
MONITORING_WALLET_ADDRESS=

# --- Tracing (optional). Leave blank to disable. ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# --- App base URL. Set to the deployed origin (used by the x402 route and the
# ERC-8004 registration document). ---
APP_BASE_URL=http://localhost:3000
